PORT=3000
NODE_ENV=production

# TikTok Events API endpoint.
TIKTOK_ENDPOINT=https://business-api.tiktok.com/open_api/v1.3/event/track/

# Server key bảo vệ endpoint. Truyền qua:
#   &server_key=... | &key=... | &sk=... | header x-server-key | header x-api-key
REQUIRE_SERVER_KEY=true
SERVER_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# CORS: restrict origin cho /capture (Landing Page domain).
# Để trống nếu không cần restrict (cho phép mọi origin).
# Ví dụ: ALLOWED_ORIGINS=https://assetshall.net,https://www.assetshall.net
ALLOWED_ORIGINS=

# Event và currency mặc định.
DEFAULT_EVENT=CompleteRegistration
DEFAULT_CURRENCY=USD

# Test Event Code — chỉ dùng khi test. Xoá hoặc để trống trên production.
DEFAULT_TEST_EVENT_CODE=

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# ---------------------------------------------------------------------------
# Lead Cache (SQLite)
# ---------------------------------------------------------------------------

# Đường dẫn file SQLite DB. Thư mục data/ sẽ tự tạo nếu chưa có.
LEAD_CACHE_DB_PATH=./data/capi-cache.db

# TTL dữ liệu cache (giây). Mặc định 10800 = 3 tiếng.
LEAD_CACHE_TTL_SECONDS=10800

# Interval xoá record hết hạn (giây). Mặc định 600 = 10 phút.
LEAD_CACHE_CLEANUP_INTERVAL_SECONDS=600

PORT=3000
NODE_ENV=production

# TikTok Events API endpoint. Keep default unless TikTok changes API version.
TIKTOK_ENDPOINT=https://business-api.tiktok.com/open_api/v1.3/event/track/

# Protect your public endpoint with your own secret.
# Production default is required. Request must include one of:
# - &server_key=YOUR_SECRET
# - &key=YOUR_SECRET
# - &sk=YOUR_SECRET
# - header x-server-key: YOUR_SECRET
# - header x-api-key: YOUR_SECRET
REQUIRE_SERVER_KEY=true
SERVER_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Optional: restrict traffic to allowed referer/origin domains, comma separated.
# Example: ALLOWED_ORIGINS=https://quickpayly.com,https://www.quickpayly.com
ALLOWED_ORIGINS=

# Hardcoded values requested by client.
DEFAULT_EVENT=CompleteRegistration
DEFAULT_CURRENCY=USD

# Optional TikTok Test Event code. Better pass as query test_event_code only while testing.
DEFAULT_TEST_EVENT_CODE=

# Request protection
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# ---------------------------------------------------------------------------
# Lead Cache (SQLite)
# ---------------------------------------------------------------------------

# Path to SQLite DB file. Directory will be created automatically.
LEAD_CACHE_DB_PATH=./data/capi-cache.db

# TTL for cached lead data in seconds. Default: 10800 (3 hours).
LEAD_CACHE_TTL_SECONDS=10800

# How often (in seconds) to clean up expired records. Default: 600 (10 minutes).
LEAD_CACHE_CLEANUP_INTERVAL_SECONDS=600
